---
import Layout from '../layouts/Layout.astro';
import dance from '../content/gallery/dance.json';
import fitness from '../content/gallery/fitness.json';
import editorial from '../content/gallery/editorial.json';
import genderUndefined from '../content/gallery/gender-undefined.json';

const categories = [
  { id: 'dance', label: 'Dance / Performance', items: dance },
  { id: 'fitness', label: 'Fitness / Physique', items: fitness },
  { id: 'editorial', label: 'Editorial / Fashion', items: editorial },
  { id: 'gender-undefined', label: 'Gender Undefined', items: genderUndefined },
];

function hasRealImages(items: { src: string }[]) {
  return items.some(item => !item.src.endsWith('/'));
}
---

<Layout title="Portfolio — Fernando Duarte" description="Photography portfolio of Fernando Duarte — dance, fitness, and editorial work.">
  <div class="pt-32 pb-24 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h1 class="font-display text-[clamp(3rem,10vw,10rem)] leading-none font-black text-black mb-16">
        Portfolio
      </h1>

      <!-- Category tabs -->
      <div class="flex gap-0 border-b border-black/10 mb-16 overflow-x-auto" id="tabs">
        {categories.map((cat, i) => (
          <button
            class={`tab-btn font-body text-[11px] tracking-[0.25em] uppercase px-6 py-4 whitespace-nowrap transition-colors border-b-2 ${i === 0 ? 'border-black text-black' : 'border-transparent text-black/30 hover:text-black'}`}
            data-tab={cat.id}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <!-- Gallery panels -->
      {categories.map((cat, i) => (
        <div id={cat.id} class={`tab-panel ${i !== 0 ? 'hidden' : ''}`}>
          {!hasRealImages(cat.items) ? (
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
              {Array.from({ length: 6 }).map(() => (
                <div class="aspect-[2/3] bg-black/5 flex items-center justify-center">
                  <p class="font-body text-xs text-black/20 tracking-widest uppercase text-center px-4">
                    Add images to<br />/images/{cat.id}/
                  </p>
                </div>
              ))}
            </div>
          ) : (
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3" id={`gallery-${cat.id}`}>
              {cat.items.map((item, idx) => (
                <button
                  class="gallery-item group relative aspect-[2/3] bg-black/5 overflow-hidden block w-full"
                  data-lightbox={JSON.stringify(item)}
                  data-index={String(idx)}
                  data-category={cat.id}
                >
                  <img
                    src={item.src}
                    alt={item.alt}
                    loading={idx < 4 ? 'eager' : 'lazy'}
                    class="w-full h-full object-cover grayscale transition-all duration-500 group-hover:scale-105 group-hover:grayscale-0"
                  />
                  <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-end p-4 opacity-0 group-hover:opacity-100">
                    <p class="font-body text-xs text-white tracking-widest uppercase">{item.credit}</p>
                  </div>
                </button>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-[200] bg-white/98 hidden items-center justify-center" role="dialog" aria-modal="true">
    <button id="lightbox-close" class="absolute top-6 right-6 font-body text-xs tracking-widest uppercase text-black/40 hover:text-black">
      Close ✕
    </button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 font-display text-4xl text-black/30 hover:text-black">‹</button>
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 font-display text-4xl text-black/30 hover:text-black">›</button>
    <div class="max-w-4xl max-h-screen px-16 flex flex-col items-center">
      <img id="lightbox-img" src="" alt="" class="max-h-[80vh] object-contain" />
      <div class="mt-4 text-center">
        <p id="lightbox-caption" class="font-body text-sm text-black/70"></p>
        <p id="lightbox-credit" class="font-body text-xs text-black/30 tracking-widest uppercase mt-1"></p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const tabs = document.querySelectorAll<HTMLElement>('.tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

  function activateTab(targetId: string) {
    tabs.forEach(t => {
      const isActive = t.getAttribute('data-tab') === targetId;
      t.classList.toggle('border-black', isActive);
      t.classList.toggle('text-black', isActive);
      t.classList.toggle('border-transparent', !isActive);
      t.classList.toggle('text-black/30', !isActive);
    });
    panels.forEach(p => p.classList.toggle('hidden', p.id !== targetId));
  }

  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-tab');
      if (target) activateTab(target);
    });
  });

  const hash = window.location.hash.replace('#', '');
  if (hash && ['dance', 'fitness', 'editorial', 'gender-undefined'].includes(hash)) activateTab(hash);

  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption');
  const lbCredit = document.getElementById('lightbox-credit');
  let currentItems: any[] = [];
  let currentIndex = 0;

  document.querySelectorAll('.gallery-item').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = JSON.parse(btn.getAttribute('data-lightbox') || '{}');
      const cat = btn.getAttribute('data-category') || '';
      currentItems = Array.from(document.querySelectorAll(`[data-category="${cat}"]`))
        .map(b => JSON.parse(b.getAttribute('data-lightbox') || '{}'));
      currentIndex = parseInt(btn.getAttribute('data-index') || '0');
      showLightbox(currentIndex);
    });
  });

  function showLightbox(idx: number) {
    const item = currentItems[idx];
    if (!item) return;
    lbImg!.src = item.src;
    lbImg!.alt = item.alt;
    lbCaption!.textContent = item.caption || '';
    lbCredit!.textContent = item.credit || '';
    lightbox?.classList.remove('hidden');
    lightbox?.classList.add('flex');
  }

  document.getElementById('lightbox-close')?.addEventListener('click', () => {
    lightbox?.classList.add('hidden');
    lightbox?.classList.remove('flex');
  });

  document.getElementById('lightbox-prev')?.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + currentItems.length) % currentItems.length;
    showLightbox(currentIndex);
  });

  document.getElementById('lightbox-next')?.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % currentItems.length;
    showLightbox(currentIndex);
  });

  document.addEventListener('keydown', e => {
    if (lightbox?.classList.contains('hidden')) return;
    if (e.key === 'Escape') { lightbox?.classList.add('hidden'); lightbox?.classList.remove('flex'); }
    if (e.key === 'ArrowLeft') { currentIndex = (currentIndex - 1 + currentItems.length) % currentItems.length; showLightbox(currentIndex); }
    if (e.key === 'ArrowRight') { currentIndex = (currentIndex + 1) % currentItems.length; showLightbox(currentIndex); }
  });
</script>
