---
import Layout from '../layouts/Layout.astro';
import site from '../content/site.json';
---

<Layout title="Fernando Duarte — Dancer & Model">
  <!-- HERO -->
  <section class="relative min-h-screen flex items-end pb-16 overflow-hidden bg-white">
    <div class="absolute inset-0 bg-white">
      <!-- Replace with: <img src="/images/hero/hero-main.jpg" alt="Fernando Duarte" class="w-full h-full object-cover grayscale" /> -->
      <div class="absolute inset-0 bg-gradient-to-br from-white via-black/5 to-black/20"></div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-white to-transparent"></div>

    <div class="relative z-10 max-w-screen-xl mx-auto px-6 pt-32 w-full">
      <h1 class="font-display leading-none" id="hero-name">
        <span class="block text-[clamp(4rem,14vw,16rem)] font-black text-black opacity-0" data-gsap="hero-line">Fernando</span>
        <span class="block text-[clamp(4rem,14vw,16rem)] font-black italic text-black opacity-0 -mt-2 md:-mt-6" data-gsap="hero-line">Duarte</span>
      </h1>
      <div class="mt-8 flex flex-col md:flex-row md:items-end gap-6 md:gap-12 opacity-0" data-gsap="hero-sub">
        <p class="font-body text-black/50 text-xs tracking-[0.4em] uppercase">
          Dancer &nbsp;·&nbsp; Model &nbsp;·&nbsp; Artist
        </p>
        <div class="flex gap-4">
          <a href="/portfolio" class="inline-block font-body text-[11px] tracking-[0.25em] uppercase bg-black text-white px-6 py-3 hover:bg-black/70 transition-colors">
            View Work
          </a>
          <a href="/contact" class="inline-block font-body text-[11px] tracking-[0.25em] uppercase border border-black text-black px-6 py-3 hover:bg-black hover:text-white transition-colors">
            Book Now
          </a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30">
      <span class="font-body text-[10px] tracking-[0.3em] uppercase text-black">Scroll</span>
      <div class="w-px h-10 bg-black"></div>
    </div>
  </section>

  <!-- FEATURED: NIGEL BARKER -->
  <section class="py-24 px-6 border-y border-black/10" data-gsap-section>
    <div class="max-w-screen-xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-20">
        <div class="w-full md:w-1/2 aspect-[3/4] relative overflow-hidden group">
          <img src="/images/featured/nigel-barker-01.jpg.png" alt="Fernando Duarte photographed by Nigel Barker — editorial shoot in red ball gown" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" />
        </div>
        <div class="md:w-1/2">
          <p class="font-body text-[11px] tracking-[0.35em] uppercase text-black/40 mb-6">Featured Work</p>
          <h2 class="font-display font-black text-[clamp(2.5rem,6vw,6rem)] leading-none text-black mb-2">Nigel</h2>
          <h2 class="font-display font-black italic text-[clamp(2.5rem,6vw,6rem)] leading-none text-black mb-8">Barker</h2>
          <p class="font-body text-black/60 text-sm leading-relaxed mb-8 max-w-sm">
            An editorial collaboration with acclaimed photographer and <em>America's Next Top Model</em> judge Nigel Barker. A defining shoot at the intersection of dance and high fashion.
          </p>
          <p class="font-body text-[11px] tracking-[0.25em] uppercase text-black/30 mb-8">
            Photography: Nigel Barker
          </p>
          <a href="/portfolio#editorial" class="inline-block font-body text-[11px] tracking-[0.25em] uppercase border border-black text-black px-6 py-3 hover:bg-black hover:text-white transition-colors">
            View Editorial
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORY PREVIEW -->
  <section class="py-24 px-6" data-gsap-section>
    <div class="max-w-screen-xl mx-auto">
      <h2 class="font-display text-[clamp(2rem,5vw,5rem)] font-black text-black mb-16 leading-none">
        The Work
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/portfolio#dance" class="group relative aspect-[2/3] bg-black/5 overflow-hidden block">
          <div class="absolute inset-0 flex items-center justify-center text-black/10 font-body text-xs tracking-widest uppercase pointer-events-none">/images/dance/</div>
          <div class="absolute inset-0 flex items-end p-6">
            <div>
              <p class="font-display text-2xl font-black text-black group-hover:italic transition-all">Dance</p>
              <p class="font-body text-[11px] tracking-widest uppercase text-black/40 mt-1">Performance · Stage</p>
            </div>
          </div>
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300"></div>
        </a>
        <a href="/portfolio#fitness" class="group relative aspect-[2/3] bg-black/5 overflow-hidden block md:mt-12">
          <div class="absolute inset-0 flex items-center justify-center text-black/10 font-body text-xs tracking-widest uppercase pointer-events-none">/images/fitness/</div>
          <div class="absolute inset-0 flex items-end p-6">
            <div>
              <p class="font-display text-2xl font-black text-black group-hover:italic transition-all">Fitness</p>
              <p class="font-body text-[11px] tracking-widest uppercase text-black/40 mt-1">Physique · Campaign</p>
            </div>
          </div>
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300"></div>
        </a>
        <a href="/portfolio#editorial" class="group relative aspect-[2/3] bg-black/5 overflow-hidden block">
          <div class="absolute inset-0 flex items-center justify-center text-black/10 font-body text-xs tracking-widest uppercase pointer-events-none">/images/editorial/</div>
          <div class="absolute inset-0 flex items-end p-6">
            <div>
              <p class="font-display text-2xl font-black text-black group-hover:italic transition-all">Editorial</p>
              <p class="font-body text-[11px] tracking-widest uppercase text-black/40 mt-1">Fashion · Print</p>
            </div>
          </div>
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300"></div>
        </a>
      </div>
    </div>
  </section>

  <!-- QUICK LINKS -->
  <section class="py-16 px-6 border-t border-black/10">
    <div class="max-w-screen-xl mx-auto flex flex-col md:flex-row gap-px bg-black/10">
      <a href="/digitals" class="flex-1 bg-white p-8 hover:bg-black group transition-colors">
        <p class="font-display text-2xl font-black text-black group-hover:text-white transition-colors mb-1">Digitals</p>
        <p class="font-body text-[11px] tracking-widest uppercase text-black/40 group-hover:text-white/50 transition-colors">For Casting Directors</p>
      </a>
      <a href="/stats" class="flex-1 bg-white p-8 hover:bg-black group transition-colors">
        <p class="font-display text-2xl font-black text-black group-hover:text-white transition-colors mb-1">Stats</p>
        <p class="font-body text-[11px] tracking-widest uppercase text-black/40 group-hover:text-white/50 transition-colors">Measurements &amp; Details</p>
      </a>
      <a href="/reel" class="flex-1 bg-white p-8 hover:bg-black group transition-colors">
        <p class="font-display text-2xl font-black text-black group-hover:text-white transition-colors mb-1">Reel</p>
        <p class="font-body text-[11px] tracking-widest uppercase text-black/40 group-hover:text-white/50 transition-colors">Movement &amp; Dance</p>
      </a>
      <a href="/contact" class="flex-1 bg-black p-8 hover:bg-white group transition-colors border border-black">
        <p class="font-display text-2xl font-black text-white group-hover:text-black transition-colors mb-1">Book</p>
        <p class="font-body text-[11px] tracking-widest uppercase text-white/50 group-hover:text-black/40 transition-colors">Get in Touch</p>
      </a>
    </div>
  </section>
</Layout>

<script>
  function initAnimations() {
    if (typeof gsap === 'undefined') {
      document.querySelectorAll('[data-gsap]').forEach(el => {
        (el as HTMLElement).style.opacity = '1';
      });
      return;
    }

    const lines = document.querySelectorAll('[data-gsap="hero-line"]');
    const sub = document.querySelector('[data-gsap="hero-sub"]');

    gsap.fromTo(lines,
      { y: 40, opacity: 0 },
      { y: 0, opacity: 1, duration: 1.2, stagger: 0.12, ease: 'power3.out', delay: 0.2 }
    );

    if (sub) {
      gsap.fromTo(sub,
        { y: 16, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.9, ease: 'power2.out', delay: 0.8 }
      );
    }

    document.querySelectorAll('[data-gsap-section]').forEach(section => {
      gsap.fromTo(section,
        { opacity: 0, y: 30 },
        { opacity: 1, y: 0, duration: 0.9, ease: 'power2.out',
          scrollTrigger: { trigger: section, start: 'top 80%' } }
      );
    });
  }

  window.addEventListener('load', initAnimations);
</script>
