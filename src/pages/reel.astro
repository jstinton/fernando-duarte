---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reel — Fernando Duarte" description="Movement and dance reels featuring Fernando Duarte.">
  <div class="pt-32 pb-24 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h1 class="font-display text-[clamp(3rem,10vw,10rem)] leading-none uppercase text-fd-cream mb-6">
        Movement
      </h1>
      <p class="font-body text-fd-cream/50 text-sm tracking-widest uppercase mb-16">Dance Reel &amp; Performance Film</p>

      <!-- Primary reel slot -->
      <div class="w-full aspect-video bg-fd-gray mb-6 flex items-center justify-center relative overflow-hidden">
        <!--
          TO ADD YOUR REEL:
          Replace this placeholder div with:
          <video src="/video/reel-main.mp4" controls poster="/images/hero/reel-poster.jpg" class="w-full h-full object-cover">
            Your browser does not support the video tag.
          </video>

          Or for autoplay background loop:
          <video src="/video/reel-main.mp4" autoplay muted loop playsinline class="w-full h-full object-cover"></video>
        -->
        <div class="text-center px-8">
          <p class="font-display text-4xl text-fd-cream/20 uppercase mb-4">Reel</p>
          <p class="font-body text-xs text-fd-cream/20 tracking-widest uppercase">Add video to /public/video/reel-main.mp4</p>
          <p class="font-body text-xs text-fd-cream/20 tracking-widest uppercase mt-2">Then replace this placeholder with a &lt;video&gt; element</p>
        </div>
        <!-- Red accent line -->
        <div class="absolute bottom-0 left-0 w-full h-px bg-fd-red/30"></div>
      </div>

      <!-- Caption below primary reel -->
      <p class="font-body text-xs text-fd-cream/30 tracking-[0.2em] uppercase mb-24">
        Primary Reel — HD · Replace with /video/reel-main.mp4
      </p>

      <!-- Secondary video slots -->
      <h2 class="font-display text-2xl uppercase text-fd-cream mb-8 tracking-wide">Additional Clips</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="aspect-video bg-fd-gray flex flex-col items-center justify-center gap-3 border border-fd-cream/5">
          <!--
            Replace with:
            <video src="/video/clip-02.mp4" controls class="w-full h-full object-cover"></video>
          -->
          <p class="font-display text-xl text-fd-cream/20 uppercase">Clip 02</p>
          <p class="font-body text-xs text-fd-cream/20 tracking-widest uppercase text-center px-8">/video/clip-02.mp4</p>
        </div>
        <div class="aspect-video bg-fd-gray flex flex-col items-center justify-center gap-3 border border-fd-cream/5">
          <!--
            Replace with:
            <video src="/video/clip-03.mp4" controls class="w-full h-full object-cover"></video>
          -->
          <p class="font-display text-xl text-fd-cream/20 uppercase">Clip 03</p>
          <p class="font-body text-xs text-fd-cream/20 tracking-widest uppercase text-center px-8">/video/clip-03.mp4</p>
        </div>
      </div>

      <p class="font-body text-xs text-fd-cream/30 tracking-widest uppercase mt-12 text-center">
        All reels are native HD — no external platform redirects.
      </p>

      <div class="mt-12 text-center">
        <a href="/contact" class="inline-block font-body text-xs tracking-[0.2em] uppercase bg-fd-red text-fd-cream px-8 py-4 hover:bg-fd-cream hover:text-fd-black transition-colors">
          Book Fernando
        </a>
      </div>
    </div>
  </div>
</Layout>
