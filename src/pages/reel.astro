---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reel — Fernando Duarte" description="Movement and dance reels featuring Fernando Duarte.">
  <div class="pt-32 pb-24 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h1 class="font-display text-[clamp(3rem,10vw,10rem)] leading-none font-black text-black mb-6">
        Movement
      </h1>
      <p class="font-body text-black/40 text-sm tracking-widest uppercase mb-16">Dance Reel &amp; Performance Film</p>

      <!-- Primary reel -->
      <div class="w-full aspect-video mb-6 overflow-hidden border border-black/10">
        <iframe
          src="https://www.youtube.com/embed/zXm2bVko10c"
          title="Fernando Duarte — Dance Reel"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full"
        ></iframe>
      </div>

      <p class="font-body text-[11px] text-black/30 tracking-[0.2em] uppercase mb-24">
        Dance Reel — Fernando Duarte
      </p>

      <div class="mt-16 text-center">
        <a href="/contact" class="inline-block font-body text-[11px] tracking-[0.25em] uppercase bg-black text-white px-8 py-4 hover:bg-black/70 transition-colors">
          Book Fernando
        </a>
      </div>
    </div>
  </div>
</Layout>
