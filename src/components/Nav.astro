---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/reel', label: 'Reel' },
  { href: '/digitals', label: 'Digitals' },
  { href: '/stats', label: 'Stats' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-screen-xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="font-display text-black text-xl italic tracking-wide hover:opacity-50 transition-opacity">
      Fernando Duarte
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`font-body text-[11px] tracking-[0.25em] uppercase transition-opacity hover:opacity-40 ${currentPath === link.href ? 'opacity-100' : 'opacity-60'}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Toggle menu">
      <span class="w-6 h-px bg-black block transition-all"></span>
      <span class="w-6 h-px bg-black block transition-all"></span>
      <span class="w-4 h-px bg-black block transition-all"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-black/10">
    <nav class="flex flex-col px-6 py-6 gap-5">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`font-display text-2xl italic tracking-wide transition-opacity hover:opacity-40 ${currentPath === link.href ? 'opacity-100' : 'opacity-70'}`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav?.classList.add('bg-white/95', 'backdrop-blur-sm', 'border-b', 'border-black/10');
    } else {
      nav?.classList.remove('bg-white/95', 'backdrop-blur-sm', 'border-b', 'border-black/10');
    }
  });

  toggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
