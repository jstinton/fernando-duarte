---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/reel', label: 'Reel' },
  { href: '/digitals', label: 'Digitals' },
  { href: '/stats', label: 'Stats' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 mix-blend-normal">
  <div class="max-w-screen-xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="font-display text-fd-cream text-xl tracking-[0.15em] uppercase hover:text-fd-red transition-colors">
      Fernando Duarte
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`font-body text-xs tracking-[0.2em] uppercase transition-colors hover:text-fd-red ${currentPath === link.href ? 'text-fd-red' : 'text-fd-cream/80'}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Toggle menu">
      <span class="w-6 h-px bg-fd-cream block transition-all"></span>
      <span class="w-6 h-px bg-fd-cream block transition-all"></span>
      <span class="w-4 h-px bg-fd-cream block transition-all"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-fd-black/95 backdrop-blur-sm border-t border-fd-cream/10">
    <nav class="flex flex-col px-6 py-6 gap-5">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`font-display text-2xl tracking-[0.1em] uppercase transition-colors hover:text-fd-red ${currentPath === link.href ? 'text-fd-red' : 'text-fd-cream'}`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  // Scroll effect: add solid bg after scrolling
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      nav?.classList.add('bg-fd-black/90', 'backdrop-blur-sm', 'border-b', 'border-fd-cream/10');
    } else {
      nav?.classList.remove('bg-fd-black/90', 'backdrop-blur-sm', 'border-b', 'border-fd-cream/10');
    }
  });

  // Mobile toggle
  toggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
