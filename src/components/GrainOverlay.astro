---
// GrainOverlay component
// The grain effect is applied globally via Layout.astro's body::after pseudo-element.
// This component is available if you need a scoped grain overlay on a specific section.
// Usage: <GrainOverlay opacity={0.15} />

interface Props {
  opacity?: number;
  zIndex?: number;
}

const { opacity = 0.18, zIndex = 10 } = Astro.props;
---

<div
  class="absolute inset-0 pointer-events-none"
  style={`z-index: ${zIndex}; opacity: ${opacity};`}
  aria-hidden="true"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
    <filter id="grain-scoped">
      <feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="4" stitchTiles="stitch" />
      <feColorMatrix type="saturate" values="0" />
    </filter>
    <rect width="100%" height="100%" filter="url(#grain-scoped)" opacity="1" />
  </svg>
</div>
