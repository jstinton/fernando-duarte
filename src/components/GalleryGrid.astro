---
interface GalleryItem {
  id: string;
  src: string;
  alt: string;
  caption?: string;
  credit?: string;
  featured?: boolean;
}

interface Props {
  items: GalleryItem[];
  category: string;
  columns?: 2 | 3 | 4;
}

const { items, category, columns = 4 } = Astro.props;

const colClass = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4',
}[columns];

// Detect if images are placeholders (src ends with /)
const hasImages = items.some(item => !item.src.endsWith('/'));
---

{!hasImages ? (
  <div class={`grid ${colClass} gap-3`}>
    {Array.from({ length: 6 }).map((_, idx) => (
      <div class="aspect-[2/3] bg-fd-gray border border-fd-cream/5 flex items-center justify-center">
        <p class="font-body text-xs text-fd-cream/20 tracking-widest uppercase text-center px-4">
          Add images to<br />/images/{category}/
        </p>
      </div>
    ))}
  </div>
) : (
  <div class={`grid ${colClass} gap-3`} id={`gallery-${category}`}>
    {items.map((item, idx) => (
      <button
        class="gallery-item group relative aspect-[2/3] bg-fd-gray overflow-hidden block w-full"
        data-lightbox={JSON.stringify(item)}
        data-index={String(idx)}
        data-category={category}
      >
        <img
          src={item.src}
          alt={item.alt}
          loading={idx < 4 ? 'eager' : 'lazy'}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-fd-black/0 group-hover:bg-fd-black/30 transition-colors duration-300 flex items-end p-4 opacity-0 group-hover:opacity-100">
          <p class="font-body text-xs text-fd-cream tracking-widest uppercase">{item.credit}</p>
        </div>
      </button>
    ))}
  </div>
)}
